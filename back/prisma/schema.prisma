// Modelo de datos del sistema de kioscos.
//
// Base de datos: PostgreSQL (en producción: Neon; en local: la misma URL vía .env).
//   Nota: medio_pago y tipo se guardan como String (con valores controlados
//   desde el código) por simplicidad. Se podrían convertir a enum más adelante.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Empresa = el kiosco (tenant). Cada kiosco ve SOLO sus datos. ──
model Empresa {
  id        Int      @id @default(autoincrement())
  nombre    String
  createdAt DateTime @default(now())

  productos   Producto[]
  clientes    Cliente[]
  ventas      Venta[]
  movimientos MovimientoCaja[]
  cierres     CierreCaja[]

  @@map("empresas")
}

model Producto {
  id           Int      @id @default(autoincrement())
  empresaId    Int      @map("empresa_id")
  nombre       String
  codigoBarras String?  @map("codigo_barras")
  precioVenta  Decimal  @map("precio_venta")
  precioCosto  Decimal  @map("precio_costo")
  stockActual  Int      @default(0) @map("stock_actual")
  stockMinimo  Int      @default(0) @map("stock_minimo")
  createdAt    DateTime @default(now())

  empresa    Empresa     @relation(fields: [empresaId], references: [id])
  ventaItems VentaItem[]

  // El código de barras es único DENTRO de cada empresa (no global).
  @@unique([empresaId, codigoBarras])
  @@index([empresaId])
  @@map("productos")
}

model Cliente {
  id        Int      @id @default(autoincrement())
  empresaId Int      @map("empresa_id")
  nombre    String
  // Saldo de la cuenta corriente / fiado. Positivo = el cliente debe.
  saldo     Decimal  @default(0)
  createdAt DateTime @default(now())

  empresa     Empresa          @relation(fields: [empresaId], references: [id])
  ventas      Venta[]
  movimientos MovimientoCaja[]

  @@index([empresaId])
  @@map("clientes")
}

model Venta {
  id        Int      @id @default(autoincrement())
  empresaId Int      @map("empresa_id")
  fechaHora DateTime @default(now()) @map("fecha_hora")
  total     Decimal
  // medio_pago: "efectivo" | "transferencia" | "fiado"
  medioPago String   @map("medio_pago")
  clienteId Int?     @map("cliente_id")

  empresa Empresa     @relation(fields: [empresaId], references: [id])
  cliente Cliente?    @relation(fields: [clienteId], references: [id])
  items   VentaItem[]

  @@index([empresaId])
  @@index([empresaId, fechaHora])
  @@map("ventas")
}

model VentaItem {
  id         Int     @id @default(autoincrement())
  ventaId    Int     @map("venta_id")
  // Opcional: los ítems de "venta rápida" (monto suelto) no tienen producto.
  productoId Int?    @map("producto_id")
  // Texto libre para esos ítems manuales (ej: "Varios").
  descripcion String?
  cantidad   Int
  // Precio congelado al momento de la venta (NO se lee el precio actual).
  precioUnitario Decimal @map("precio_unitario")

  venta    Venta     @relation(fields: [ventaId], references: [id], onDelete: Cascade)
  producto Producto? @relation(fields: [productoId], references: [id])

  @@index([ventaId])
  @@map("venta_items")
}

// ── Cierre de caja (arqueo). ──
// Cada cierre "corta" la caja en un momento: lo que pasó DESPUÉS de este cierre
// arranca la caja siguiente. Queda guardado cuánto debería haber (según el
// sistema), cuánto se contó de verdad, y la diferencia.
model CierreCaja {
  id               Int      @id @default(autoincrement())
  empresaId        Int      @map("empresa_id")
  // Día del cierre como clave AAAA-MM-DD (hora local), solo para mostrar.
  fecha            String
  // Lo que el sistema calculó que debería haber en efectivo al cerrar.
  efectivoEsperado Decimal  @map("efectivo_esperado")
  // Lo que el kiosquero contó físicamente.
  efectivoContado  Decimal  @map("efectivo_contado")
  // contado - esperado. Positivo = sobra; negativo = falta.
  diferencia       Decimal
  // El momento exacto del cierre es el corte: marca el fin de una caja y el
  // arranque de la siguiente.
  createdAt        DateTime @default(now()) @map("created_at")

  empresa Empresa @relation(fields: [empresaId], references: [id])

  @@index([empresaId])
  @@index([empresaId, createdAt])
  @@map("cierres_caja")
}

model MovimientoCaja {
  id          Int      @id @default(autoincrement())
  empresaId   Int      @map("empresa_id")
  fechaHora   DateTime @default(now()) @map("fecha_hora")
  // tipo: "venta" | "gasto" | "retiro" | "apertura" | "cobro_fiado"
  tipo        String
  monto       Decimal
  descripcion String
  // Opcional: liga el movimiento a un cliente (ventas fiadas y cobros de fiado).
  clienteId   Int?     @map("cliente_id")

  empresa Empresa  @relation(fields: [empresaId], references: [id])
  cliente Cliente? @relation(fields: [clienteId], references: [id])

  @@index([empresaId])
  @@index([empresaId, fechaHora])
  @@map("movimientos_caja")
}
