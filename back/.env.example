# ── Variables de entorno del backend ──
# Copiá este archivo como ".env" y completá los valores.
# El archivo .env NUNCA se sube a GitHub (está en .gitignore).

# Puerto del servidor (en Render se setea solo).
PORT=3000

# Base de datos.
#
# DESARROLLO local (lo que usás hoy): SQLite, un archivo, sin instalar nada.
DATABASE_URL="file:./dev.db"
#
# PRODUCCIÓN: PostgreSQL (Neon). La URL te la da Neon al crear la base.
# Se carga como variable de entorno en Render, NO acá.
# Ejemplo de cómo se ve:
# DATABASE_URL="postgresql://usuario:password@ep-xxx.neon.tech/kiosco?sslmode=require"

# URL pública del front (para CORS en producción). En local dejala vacía.
# Ejemplo: FRONT_URL="https://kiosco-front.onrender.com"
FRONT_URL=
